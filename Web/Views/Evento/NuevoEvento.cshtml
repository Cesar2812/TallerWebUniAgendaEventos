@model DtoEvento
@{
    ViewData["Title"] = "Nuevo Evento";
}

<div class="card shadow mb-4">

    <div class="card-header py-3 bg-second-primary">
        <h6 class="m-0 font-weight-bold text-white">Nuevo Evento</h6>
    </div>

    <div class="card-body">

        <form asp-action="NuevoEvento" asp-controller="Evento" method="post">
            <div class="mb-3">
                <label for="exampleFormControlInput1" class="form-label">Nombre Del Evento</label>
                <input type="text" class="form-control" id="exampleFormControlInput1" asp-for="nameActivitie">
                <span asp-validation-for="nameActivitie" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label for="exampleFormControlInput1" class="form-label">Fecha De Inicio</label>
                <input type="date" class="form-control" id="exampleFormControlInput1" placeholder="name@example.com" asp-for="starDate">
                <span asp-validation-for="starDate" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label for="exampleFormControlInput1" class="form-label">Fecha De Finalizacion</label>
                <input type="date" class="form-control" id="exampleFormControlInput1" placeholder="name@example.com" asp-for="endDate">
                <span asp-validation-for="endDate" class="text-danger"></span>
            </div>

            <div class="mb-0">
                <label for="exampleFormControlInput1" class="form-label">Categoria Del Evento</label>
            </div>

            <div class="mb-0">
                <select class="form-select form-select-sm" aria-label="Small select example" asp-for="categorieId">
                    <option value="0">Seleccione Una Categoria</option>
                    @foreach (var item in ViewBag.Categorias)
                    {
                        <option value="@item.id">
                            @item.nameCategory
                        </option>
                    }
                </select>
                <span asp-validation-for="categorieId" class="text-danger"></span>
            </div>

            <br />

            <div class="mb-3">
                <label for="exampleFormControlTextarea1" class="form-label">Observaciones</label>
                <textarea class="form-control" id="exampleFormControlTextarea1" rows="3" asp-for="notes"></textarea>
                <span asp-validation-for="notes" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-floppy2-fill"></i> Guardar</button>
            <a asp-action="ListEvento" asp-controller="Evento" class="btn btn-warning"><i class="bi bi-card-checklist"></i> Volver a la Lista</a>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        @if (TempData["MensajeExito"] != null)
        {
                        <text>
                                swal({
                                    title: "Éxito",
                                    text:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["MensajeExito"])),
                                    type: "success"
                                }, function () {
                                    window.location.href = '@Url.Action("ListEvento", "Evento")';
                                });
                        </text>
        }

        @if (TempData["MensajeError"] != null)
        {
                        <text>
                                swal({
                                    title: "Error",
                                        text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["MensajeError"])),
                                    type: "error"
                                });
                        </text>
        }
    </script>
}